# Finance Agent HTTP: /briefing, POST /sygnif/sentiment, POST /overseer/commentary, /health, /training,
# GET|POST /sygnif/swarm (token: SYGNIF_SWARM_WEBHOOK_TOKEN)
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir requests feedparser numpy pandas scikit-learn xgboost

# Shared prompt + live Bybit snapshot (same as Freqtrade strategies)
COPY user_data/strategies/sentiment_constants.py /app/sentiment_constants.py
COPY user_data/strategies/live_market_snapshot.py /app/live_market_snapshot.py
COPY finance_agent/ /app/finance_agent/
# BTC ML runner + upstream study trees (paths relative to /app/prediction_agent)
COPY prediction_agent/ /app/prediction_agent/
# Signed Bybit reads for Swarm closed-PnL (``compute_swarm`` → ``bybit_linear_hedge``)
COPY trade_overseer/ /app/trade_overseer/

ENV PYTHONPATH=/app
EXPOSE 8091

CMD ["python3", "/app/finance_agent/http_main.py"]
