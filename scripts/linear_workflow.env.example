# Sygnif linear workflow — env alignment (.cursor/rules/sygnif-linear-workflow.mdc)
#
# Order for external checks (sequential; skip what you do not need):
#   1) Worker health     → CURSOR_WORKER_HEALTH_URL
#   2) Finance agent HTTP (briefing / sentiment) → FINANCE_AGENT_HTTP_URL
#   3) Overseer          → OVERSEER_URL
#
# Copy to linear_workflow.env (gitignored) and adjust:
#   cp scripts/linear_workflow.env.example scripts/linear_workflow.env
#
# Load with your shell or finance-agent service:
#   set -a && source scripts/linear_workflow.env && set +a

# Step 2 — local repo first (worker is the coordinator entrypoint)
CURSOR_WORKER_HEALTH_URL=http://127.0.0.1:8093/healthz

# Step 3a — finance-agent HTTP (host systemd or Docker publish 127.0.0.1:8091)
FINANCE_AGENT_HTTP_URL=http://127.0.0.1:8091

# Step 3b — trade overseer (Docker trade-overseer on host loopback)
OVERSEER_URL=http://127.0.0.1:8090

# Network monorepo submodule (git submodule at ./network)
NETWORK_SUBMODULE_REMOTE=https://github.com/Giansn/Network.git
NETWORK_SUBMODULE_BRANCH=main
