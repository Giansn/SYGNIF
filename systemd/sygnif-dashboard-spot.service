[Unit]
Description=Sygnif Spot Dashboard
After=docker.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/SYGNIF
EnvironmentFile=-/home/ubuntu/SYGNIF/.env
ExecStart=/usr/bin/python3 /home/ubuntu/SYGNIF/dashboard_server.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
