//@version=5
indicator("SYGNIF BTC Predict", overlay=true)

// Inputs
int rsiP    = input.int(14, "RSI")
int momP    = input.int(10, "Momentum")
int rocP    = input.int(12, "ROC")
int wrP     = input.int(14, "Williams %R")
int bbP     = input.int(20, "Bollinger")
int atrP    = input.int(14, "ATR")
int volP    = input.int(20, "Vol SMA")
int slopeP  = input.int(5,  "Slope Bars")
bool tbl    = input.bool(true, "Dashboard")
bool arrows = input.bool(true, "Signals")

// Indicators
rsiV   = ta.rsi(close, rsiP)
rsiF   = ta.rsi(close, 6)
[ml, sl, hl] = ta.macd(close, 12, 26, 9)
bbM    = ta.sma(close, bbP)
bbS    = ta.stdev(close, bbP)
bbU    = bbM + 2 * bbS
bbL    = bbM - 2 * bbS
atr    = ta.atr(atrP)
mom    = close - close[momP]
roc    = (close - close[rocP]) / close[rocP] * 100
hh     = ta.highest(high, wrP)
ll     = ta.lowest(low, wrP)
wr     = -100 * (hh - close) / (hh - ll)
vr     = volume / ta.sma(volume, volP)
e12    = ta.ema(close, 12)
e26    = ta.ema(close, 26)

// Score each indicator -1..+1
s_rsi  = (rsiV - 50) / 50
s_rsiF = (rsiF - 50) / 50

float s_macd = 0
if hl > 0
    s_macd := math.min(hl / atr, 1)
else
    s_macd := math.max(hl / atr, -1)

s_bb   = ((close - bbL) / (bbU - bbL) - 0.5) * 2
s_mom  = math.max(math.min(mom / atr / 3, 1), -1)
s_roc  = math.max(math.min(roc / 3, 1), -1)
s_wr   = -(wr + 50) / 50

float s_vol = 0
if mom > 0
    s_vol := math.min((vr - 1) / 2, 1)
else
    s_vol := -math.min((vr - 1) / 2, 1)

float s_ema = 0
if close > e12 and e12 > e26
    s_ema := 1
else if close < e12 and e12 < e26
    s_ema := -1
else
    s_ema := (close - e26) / atr * 0.3

s_slope = math.max(math.min((close - close[slopeP]) / (atr * slopeP), 1), -1)

// Composite 0..100
raw = (s_rsi * 15 + s_rsiF * 10 + s_macd * 15 + s_bb * 8 + s_mom * 10 + s_roc * 5 + s_wr * 8 + s_vol * 5 + s_ema * 14 + s_slope * 10) / 100
score = ta.ema(math.max(math.min((raw + 1) / 2 * 100, 100), 0), 3)

// Direction
bull = score >= 60
bear = score <= 40
conf = math.abs(score - 50) * 2

// Consensus (3 voters)
int v1 = bull ? 1 : bear ? -1 : 0
int v2 = 0
if hl > 0 and close > e26
    v2 := 1
if hl < 0 and close < e26
    v2 := -1
int v3 = 0
if rsiV > 55 and mom > 0
    v3 := 1
if rsiV < 45 and mom < 0
    v3 := -1
int votes = v1 + v2 + v3

// Background
color bg = color.new(color.gray, 95)
if bull
    bg := color.new(color.green, 90)
if bear
    bg := color.new(color.red, 90)
bgcolor(bg)

// Arrows on flips
lo = bull and not bull[1] and arrows
sh = bear and not bear[1] and arrows
plotshape(lo, "Buy",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(sh, "Sell", shape.triangledown, location.abovebar, color.red,   size=size.small)

// Data window
plot(score, "Score", color.new(color.blue, 100), display=display.data_window)
plot(conf,  "Conf",  color.new(color.blue, 100), display=display.data_window)

// Dashboard
if tbl and barstate.islast
    var t = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 20), border_width=1)

    string dir = bull ? "UP" : bear ? "DOWN" : "—"
    string con = votes >= 2 ? "BULLISH" : votes <= -2 ? "BEARISH" : "MIXED"

    color dc = color.gray
    if bull
        dc := color.green
    if bear
        dc := color.red

    color cc = color.orange
    if votes >= 2
        cc := color.green
    if votes <= -2
        cc := color.red

    color rc = rsiV > 60 ? color.green : rsiV < 40 ? color.red : color.white
    color mc = hl > 0 ? color.green : color.red
    color wc = wr < -80 ? color.green : wr > -20 ? color.red : color.white
    color vc = vr > 1.5 ? color.green : color.white

    table.cell(t, 0, 0, "SYGNIF",      text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 1, 0, "5m BTC",      text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1, "Direction",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, dir,           text_color=dc,          text_size=size.normal)
    table.cell(t, 0, 2, "Confidence",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(conf, 1)) + "%", text_color=dc, text_size=size.normal)
    table.cell(t, 0, 3, "Consensus",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3, con,           text_color=cc,          text_size=size.normal)
    table.cell(t, 0, 4, "RSI",          text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(math.round(rsiV, 1)), text_color=rc, text_size=size.tiny)
    table.cell(t, 0, 5, "MACD",         text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(math.round(hl, 1)),   text_color=mc, text_size=size.tiny)
    table.cell(t, 0, 6, "W%R",          text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(math.round(wr, 1)),   text_color=wc, text_size=size.tiny)
    table.cell(t, 0, 7, "Vol",          text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(math.round(vr, 2)) + "x", text_color=vc, text_size=size.tiny)

// Alerts
alertcondition(lo, "SYGNIF Buy",  "SYGNIF 5m: BTC BULLISH")
alertcondition(sh, "SYGNIF Sell", "SYGNIF 5m: BTC BEARISH")
