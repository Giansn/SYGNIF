//@version=6
strategy("SYGNIF BTC 5m", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_value=0.06, slippage=2, initial_capital=10000, max_boxes_count=500, max_lines_count=500)

// ── Inputs ──
zzLen    = input.int(9,     "ZigZag Length", minval=5)
fibFact  = input.float(0.33,"MSB Fib Confirm", step=0.01)
pivotLen = input.int(10,    "Pivot Lookback", minval=5)
fibLen   = input.int(50,    "Fib Lookback", minval=20)
sfVol    = input.float(3.0, "SF Vol Filter %", step=0.5)
tpMul    = input.float(2.5, "TP (x ATR)", step=0.5)
slMul    = input.float(1.5, "SL (x ATR)", step=0.5)
minSc    = input.int(70,    "Min Score", minval=60, maxval=85)
cdBars   = input.int(24,    "Cooldown Bars", minval=6)
tbl      = input.bool(true, "Dashboard")
showOB   = input.bool(true, "Show Order Blocks")
showLiq  = input.bool(true, "Show Liq Zones")
fibPlt   = input.bool(true, "Show Fib")

// ── Core indicators ──
rsiV = ta.rsi(close, 14)
rsiF = ta.rsi(close, 6)
[ml, sl, hl] = ta.macd(close, 12, 26, 9)
bbM  = ta.sma(close, 20)
bbS  = ta.stdev(close, 20)
bbU  = bbM + 2 * bbS
bbL  = bbM - 2 * bbS
atr  = ta.atr(14)
mom  = close - close[10]
roc  = (close - close[12]) / close[12] * 100
wr   = -100 * (ta.highest(high, 14) - close) / (ta.highest(high, 14) - ta.lowest(low, 14))
vr   = volume / ta.sma(volume, 20)
e12  = ta.ema(close, 12)
e26  = ta.ema(close, 26)
e50  = ta.ema(close, 50)
e120 = ta.ema(close, 120)

// ── Higher TF ──
e50_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
rsi_1h = request.security(syminfo.tickerid, "60", ta.rsi(close, 14))
htfUp  = close > e50_1h and rsi_1h > 45
htfDn  = close < e50_1h and rsi_1h < 55

// ══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE (ZigZag + MSB + Order Blocks)
// ══════════════════════════════════════════════════════════════════════════════

to_up   = high >= ta.highest(zzLen)
to_down = low <= ta.lowest(zzLen)

var int trend = 1
trend := trend == 1 and to_down ? -1 : trend == -1 and to_up ? 1 : trend

// Track swing points
lastUpSince  = ta.barssince(to_up[1])
lastDnSince  = ta.barssince(to_down[1])
lowVal  = ta.lowest(nz(lastUpSince > 0 ? lastUpSince : 1, 1))
highVal = ta.highest(nz(lastDnSince > 0 ? lastDnSince : 1, 1))

var float[] hiPts = array.new_float(0)
var float[] loPts = array.new_float(0)
var int[]   hiIdx = array.new_int(0)
var int[]   loIdx = array.new_int(0)

if ta.change(trend) != 0
    if trend == 1
        array.push(loPts, lowVal)
        array.push(loIdx, bar_index - ta.barssince(lowVal == low))
    if trend == -1
        array.push(hiPts, highVal)
        array.push(hiIdx, bar_index - ta.barssince(highVal == high))

// Get recent swing points
float h0 = array.size(hiPts) > 0 ? array.last(hiPts) : na
float h1 = array.size(hiPts) > 1 ? array.get(hiPts, array.size(hiPts) - 2) : na
float l0 = array.size(loPts) > 0 ? array.last(loPts) : na
float l1 = array.size(loPts) > 1 ? array.get(loPts, array.size(loPts) - 2) : na

// Market structure state
var int mktStr = 1
lastL0 = ta.valuewhen(ta.change(mktStr) != 0, nz(l0), 0)
lastH0 = ta.valuewhen(ta.change(mktStr) != 0, nz(h0), 0)

if not na(l0) and not na(l1) and not na(h0) and not na(h1)
    if lastL0 != l0 or lastH0 != h0
        if mktStr == 1 and l0 < l1 and l0 < l1 - math.abs(nz(h0) - l1) * fibFact
            mktStr := -1
        if mktStr == -1 and h0 > h1 and h0 > h1 + math.abs(h1 - nz(l0)) * fibFact
            mktStr := 1

bullMSB = ta.change(mktStr) > 0
bearMSB = ta.change(mktStr) < 0
mktBull = mktStr == 1
mktBear = mktStr == -1

// ── Order Block detection ──
// Bullish OB = last bearish candle before the bullish MSB move
// Bearish OB = last bullish candle before the bearish MSB move
var float buOBtop = na
var float buOBbtm = na
var float beOBtop = na
var float beOBbtm = na
var bool  buOBactive = false
var bool  beOBactive = false

if bullMSB
    for i = 1 to 20
        if close[i] < open[i]
            buOBtop := high[i]
            buOBbtm := low[i]
            buOBactive := true
            break

if bearMSB
    for i = 1 to 20
        if close[i] > open[i]
            beOBtop := high[i]
            beOBbtm := low[i]
            beOBactive := true
            break

// Price in OB zone
inBullOB = buOBactive and close >= buOBbtm and close <= buOBtop
inBearOB = beOBactive and close >= beOBbtm and close <= beOBtop

// OB invalidation: price closes below bull OB or above bear OB
if buOBactive and close < buOBbtm - atr * 0.5
    buOBactive := false
if beOBactive and close > beOBtop + atr * 0.5
    beOBactive := false

// ── Fibonacci ──
fibHi  = ta.highest(high, fibLen)
fibLo  = ta.lowest(low, fibLen)
fibRng = fibHi - fibLo
fib382 = fibHi - fibRng * 0.382
fib500 = fibHi - fibRng * 0.500
fib618 = fibHi - fibRng * 0.618
fib786 = fibHi - fibRng * 0.786

float fibScore = 0.0
if close <= fib618 and close >= fib786
    fibScore := 1.0
else if close <= fib382 and close > fib618
    fibScore := 0.5
else if close > fibHi - fibRng * 0.236
    fibScore := -0.7

fibLongB  = (low <= fib618 and close > fib618 and close > open) or (low <= fib786 and close > fib786 and close > open)
fibShortB = (high >= fibHi - fibRng * 0.236 and close < fibHi - fibRng * 0.236 and close < open)

// ── Liquidity swings (pivot-based) ──
ph = ta.pivothigh(pivotLen, pivotLen)
pl = ta.pivotlow(pivotLen, pivotLen)

var float shTop = na
var float shBtm = na
var int   shRet = 0
var bool  shSwp = false

if not na(ph)
    shTop := high[pivotLen]
    shBtm := math.max(open[pivotLen], close[pivotLen])
    shRet := 0
    shSwp := false

var float slTopZ = na
var float slBtmZ = na
var int   slRet = 0
var bool  slSwp = false

if not na(pl)
    slTopZ := math.min(open[pivotLen], close[pivotLen])
    slBtmZ := low[pivotLen]
    slRet  := 0
    slSwp  := false

if not shSwp and not na(shTop)
    if high >= shBtm and high <= shTop and close < shBtm
        shRet += 1
if not slSwp and not na(slBtmZ)
    if low <= slTopZ and low >= slBtmZ and close > slTopZ
        slRet += 1

shSweep = not shSwp and not na(shTop) and high > shTop and close < shTop and close < open and vr > 1.3
slSweep = not slSwp and not na(slBtmZ) and low < slBtmZ and close > slBtmZ and close > open and vr > 1.3

if high > nz(shTop)
    shSwp := true
if low < nz(slBtmZ)
    slSwp := true

// Failure swing = sweep + reversal at real S/R
volPct = math.abs(close - e120) / e120 * 100
fsLong  = slSweep and volPct > sfVol and slRet >= 1
fsShort = shSweep and volPct > sfVol and shRet >= 1

// ── Liq + structure composite score ──
float liqScore = 0.0
if slSweep or fsLong
    liqScore := 1.0
else if shSweep or fsShort
    liqScore := -1.0

float msbScore = 0.0
if mktBull
    msbScore := 0.6
if mktBear
    msbScore := -0.6
if bullMSB
    msbScore := 1.0
if bearMSB
    msbScore := -1.0

float obScore = 0.0
if inBullOB and mktBull
    obScore := 1.0
if inBearOB and mktBear
    obScore := -1.0

// ── Scoring (14 indicators) ──
s1  = (rsiV - 50) / 50
s2  = (rsiF - 50) / 50
s3  = hl > 0 ? math.min(hl / atr, 1.0) : math.max(hl / atr, -1.0)
s4  = ((close - bbL) / (bbU - bbL) - 0.5) * 2
s5  = math.max(math.min(mom / atr / 3, 1.0), -1.0)
s6  = math.max(math.min(roc / 3, 1.0), -1.0)
s7  = -(wr + 50) / 50
s8  = mom > 0 ? math.min((vr - 1) / 2, 1.0) : -math.min((vr - 1) / 2, 1.0)
float s9 = 0.0
if close > e12 and e12 > e26
    s9 := 1.0
else if close < e12 and e12 < e26
    s9 := -1.0
else
    s9 := math.max(math.min((close - e26) / atr * 0.3, 1.0), -1.0)
s10 = math.max(math.min((close - close[5]) / (atr * 5), 1.0), -1.0)
s11 = fibScore
s12 = liqScore
s13 = msbScore
s14 = obScore

raw = s1*8 + s2*5 + s3*8 + s4*4 + s5*6 + s6*3 + s7*4 + s8*3 + s9*7 + s10*5 + s11*10 + s12*10 + s13*14 + s14*13
score = ta.ema(math.max(math.min((raw/100 + 1) / 2 * 100, 100.0), 0.0), 5)

// ── Consensus — 7 voters ──
v1 = score >= 60 ? 1 : score <= 40 ? -1 : 0
v2 = hl > 0 and close > e26 ? 1 : hl < 0 and close < e26 ? -1 : 0
v3 = rsiV > 55 and mom > 0 ? 1 : rsiV < 45 and mom < 0 ? -1 : 0
v4 = fibScore >= 0.5 ? 1 : fibScore <= -0.5 ? -1 : 0
v5 = liqScore >= 0.5 ? 1 : liqScore <= -0.5 ? -1 : 0
v6 = msbScore >= 0.5 ? 1 : msbScore <= -0.5 ? -1 : 0
v7 = obScore >= 0.5 ? 1 : obScore <= -0.5 ? -1 : 0
votes = v1 + v2 + v3 + v4 + v5 + v6 + v7

// ── Entry paths ──
bullBase     = score >= minSc and votes >= 4 and vr > 1.2 and htfUp and mktBull and rsiV < 70
bearBase     = score <= (100 - minSc) and votes <= -4 and vr > 1.2 and htfDn and mktBear and rsiV > 30
// OB entry: price returned to order block in confirmed structure
obLongEntry  = inBullOB and mktBull and htfUp and votes >= 3 and rsiV < 50 and score >= 55
obShortEntry = inBearOB and mktBear and htfDn and votes <= -3 and rsiV > 50 and score <= 45
// Sweep + fib confluence
sweepLong    = slSweep and fibLongB and htfUp and mktBull and rsiV < 40
sweepShort   = shSweep and fibShortB and htfDn and mktBear and rsiV > 60
// Swing fail at retested level
sfLongEntry  = fsLong and htfUp and mktBull and votes >= 2 and rsiV < 45
sfShortEntry = fsShort and htfDn and mktBear and votes <= -2 and rsiV > 55

bull = bullBase or obLongEntry or sweepLong or sfLongEntry
bear = bearBase or obShortEntry or sweepShort or sfShortEntry

var int lastEntry = 0
cooled = bar_index - lastEntry >= cdBars
flat   = strategy.position_size == 0

// ── TP ──
float tpLong = atr * tpMul
if inBullOB and not na(shBtm) and shBtm - close > atr
    tpLong := shBtm - close
else if fsLong and e120 > close and e120 - close > atr
    tpLong := e120 - close
else if close < fib500 and fib382 - close > atr
    tpLong := fib382 - close

float tpShort = atr * tpMul
if inBearOB and not na(slTopZ) and close - slTopZ > atr
    tpShort := close - slTopZ
else if fsShort and close > e120 and close - e120 > atr
    tpShort := close - e120
else if close > fib500 and close - fib618 > atr
    tpShort := close - fib618

slD = atr * slMul

if bull and cooled and flat
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", profit=tpLong / syminfo.mintick, loss=slD / syminfo.mintick)
    lastEntry := bar_index

if bear and cooled and flat
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", profit=tpShort / syminfo.mintick, loss=slD / syminfo.mintick)
    lastEntry := bar_index

// ── Visuals ──
// Order blocks as boxes
var box buOBbox = na
var box beOBbox = na

if bullMSB and showOB and buOBactive
    buOBbox := box.new(bar_index - 20, buOBtop, bar_index + 10, buOBbtm, border_color=color.green, bgcolor=color.new(color.green, 85), text="OB", text_color=color.green, text_size=size.tiny, text_halign=text.align_right)

if bearMSB and showOB and beOBactive
    beOBbox := box.new(bar_index - 20, beOBtop, bar_index + 10, beOBbtm, border_color=color.red, bgcolor=color.new(color.red, 85), text="OB", text_color=color.red, text_size=size.tiny, text_halign=text.align_right)

if buOBactive and not na(buOBbox) and showOB
    box.set_right(buOBbox, bar_index + 5)
if beOBactive and not na(beOBbox) and showOB
    box.set_right(beOBbox, bar_index + 5)

// Liq zones
var box shBox = na
var box slBoxZ = na
if not na(ph) and showLiq
    shBox := box.new(bar_index - pivotLen, shTop, bar_index, shBtm, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 90))
if not shSwp and not na(shBox) and showLiq
    box.set_right(shBox, bar_index + 3)
if not na(pl) and showLiq
    slBoxZ := box.new(bar_index - pivotLen, slTopZ, bar_index, slBtmZ, border_color=color.new(color.teal, 60), bgcolor=color.new(color.teal, 90))
if not slSwp and not na(slBoxZ) and showLiq
    box.set_right(slBoxZ, bar_index + 3)

// MSB markers
plotshape(bullMSB, "Bull MSB", shape.labelup,   location.belowbar, color.green, text="MSB", textcolor=color.white, size=size.tiny)
plotshape(bearMSB, "Bear MSB", shape.labeldown,  location.abovebar, color.red,   text="MSB", textcolor=color.white, size=size.tiny)

// Sweep markers
plotshape(slSweep and not fsLong,  "Sweep L", shape.diamond, location.belowbar, color.new(color.lime, 0),    size=size.tiny)
plotshape(shSweep and not fsShort, "Sweep S", shape.diamond, location.abovebar, color.new(color.fuchsia, 0),  size=size.tiny)

plot(fibPlt ? fib382 : na, "Fib 38.2%", color.new(color.orange, 50), 1, plot.style_cross)
plot(fibPlt ? fib618 : na, "Fib 61.8%", color.new(color.green, 40),  2, plot.style_cross)
plot(e50_1h, "1h EMA50", color.new(color.orange, 40), 2)
plot(e120,   "EMA120",   color.new(color.yellow, 60), 1)

color bg = color.new(color.gray, 97)
if mktBull and score >= 55
    bg := color.new(color.green, 93)
if mktBear and score <= 45
    bg := color.new(color.red, 93)
bgcolor(bg)

plot(score, "Score", color.new(color.blue, 100), display=display.data_window)

// ── Dashboard ──
if tbl and barstate.islast
    var t = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 20), border_width=1)
    dir = bull ? "LONG" : bear ? "SHORT" : "FLAT"
    struc = mktBull ? "BULL" : mktBear ? "BEAR" : "—"
    color dc = bull ? color.green : bear ? color.red : color.gray
    color sc = mktBull ? color.green : mktBear ? color.red : color.gray
    con = votes >= 4 ? "STRONG" : votes >= 3 ? "YES" : votes <= -4 ? "STRONG" : votes <= -3 ? "YES" : "WAIT"
    color cc = math.abs(votes) >= 4 ? (votes > 0 ? color.green : color.red) : math.abs(votes) >= 3 ? (votes > 0 ? color.green : color.red) : color.orange
    htf = htfUp ? "UP" : htfDn ? "DN" : "—"
    color hc = htfUp ? color.green : htfDn ? color.red : color.gray
    obZ = inBullOB ? "BULL OB" : inBearOB ? "BEAR OB" : "—"
    color oc = inBullOB ? color.green : inBearOB ? color.red : color.gray
    table.cell(t, 0, 0,  "SYGNIF",      text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 1, 0,  "5m BTC",      text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1,  "Bias",        text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1,  dir,           text_color=dc,          text_size=size.normal)
    table.cell(t, 0, 2,  "Structure",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2,  struc,         text_color=sc,          text_size=size.normal)
    table.cell(t, 0, 3,  "1h Trend",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3,  htf,           text_color=hc,          text_size=size.normal)
    table.cell(t, 0, 4,  "Order Block", text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4,  obZ,           text_color=oc,          text_size=size.normal)
    table.cell(t, 0, 5,  "Consensus",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5,  con + " " + str.tostring(votes) + "/7", text_color=cc, text_size=size.small)
    table.cell(t, 0, 6,  "Score",       text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 6,  str.tostring(math.round(score, 1)), text_color=dc, text_size=size.tiny)
    rHi = na(shRet) ? "—" : str.tostring(shRet) + "x"
    rLo = na(slRet) ? "—" : str.tostring(slRet) + "x"
    table.cell(t, 0, 7,  "Retests",     text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 7,  "H:" + rHi + " L:" + rLo, text_color=color.white, text_size=size.tiny)
    float tpS = strategy.position_size > 0 ? tpLong : tpShort
    table.cell(t, 0, 8,  "TP / SL",     text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 8,  str.tostring(math.round(tpS, 0)) + " / " + str.tostring(math.round(slD, 0)), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 9,  "Fib",         text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 9,  str.tostring(math.round(fibScore, 2)), text_color=fibScore > 0 ? color.green : fibScore < 0 ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 0, 10, "ATR",         text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(math.round(atr, 0)),   text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 11, "Vol",         text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 11, str.tostring(math.round(vr, 2)) + "x", text_color=vr > 1.2 ? color.green : color.white, text_size=size.tiny)

alertcondition(bull and cooled and flat, "SYGNIF Long",  "SYGNIF: BTC LONG")
alertcondition(bear and cooled and flat, "SYGNIF Short", "SYGNIF: BTC SHORT")
