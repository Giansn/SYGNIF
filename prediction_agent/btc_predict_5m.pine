// ============================================================================
// SYGNIF BTC Prediction — 5min Timeframe
// Pine Script v5 — TradingView
//
// How to use:
//   1. Open TradingView -> BTCUSDT (or BTCUSD) on 5m chart
//   2. Pine Editor -> paste this entire script -> Add to chart
//   3. Green background = bullish, red = bearish, gray = neutral
//   4. Table in top-right shows live prediction + breakdown
//   5. Arrows mark signal flips
// ============================================================================

//@version=5
indicator("SYGNIF BTC Predict 5m", overlay=true, max_labels_count=500)

// --- Inputs ---
rsiLen       = input.int(14,   "RSI Period")
rsiFastLen   = input.int(6,    "RSI Fast Period")
macdFast     = input.int(12,   "MACD Fast")
macdSlow     = input.int(26,   "MACD Slow")
macdSig      = input.int(9,    "MACD Signal")
bbLen        = input.int(20,   "Bollinger Period")
bbDev        = input.float(2,  "Bollinger StdDev")
atrLen       = input.int(14,   "ATR Period")
momLen       = input.int(10,   "Momentum Period")
rocLen       = input.int(12,   "ROC Period")
willrLen     = input.int(14,   "Williams %R Period")
volSmaLen    = input.int(20,   "Volume SMA Period")
slopeLen     = input.int(5,    "Slope Lookback")
showTable    = input.bool(true, "Show Dashboard")
showSignals  = input.bool(true, "Show Arrow Signals")

// --- Indicators ---
rsiVal  = ta.rsi(close, rsiLen)
rsiFast = ta.rsi(close, rsiFastLen)

[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSig)

bbMid   = ta.sma(close, bbLen)
bbStd   = ta.stdev(close, bbLen)
bbUp    = bbMid + bbDev * bbStd
bbLo    = bbMid - bbDev * bbStd
bbPos   = (close - bbLo) / (bbUp - bbLo)

atrVal  = ta.atr(atrLen)
momVal  = close - close[momLen]
rocVal  = (close - close[rocLen]) / close[rocLen] * 100

hhWR    = ta.highest(high, willrLen)
llWR    = ta.lowest(low, willrLen)
willrVal = -100 * (hhWR - close) / (hhWR - llWR)

volSma   = ta.sma(volume, volSmaLen)
volRatio = volume / volSma

ema12 = ta.ema(close, 12)
ema26 = ta.ema(close, 26)

// --- Scoring (-1 to +1 per indicator) ---
rsiScore     = (rsiVal - 50.0) / 50.0
rsiFastScore = (rsiFast - 50.0) / 50.0

float macdScore = 0.0
if histLine > 0
    macdScore := math.min(histLine / atrVal, 1.0)
else
    macdScore := math.max(histLine / atrVal, -1.0)

bbScore   = (bbPos - 0.5) * 2.0
momNorm   = momVal / atrVal
momScore  = math.max(math.min(momNorm / 3.0, 1.0), -1.0)
rocScore  = math.max(math.min(rocVal / 3.0, 1.0), -1.0)
willrScr  = -(willrVal + 50.0) / 50.0

float volScore = 0.0
if momVal > 0
    volScore := math.min((volRatio - 1.0) / 2.0, 1.0)
else
    volScore := -math.min((volRatio - 1.0) / 2.0, 1.0)

float emaTrend = 0.0
if close > ema12 and ema12 > ema26
    emaTrend := 1.0
else if close < ema12 and ema12 < ema26
    emaTrend := -1.0
else
    emaTrend := (close - ema26) / atrVal * 0.3

slopeRaw   = (close - close[slopeLen]) / (atrVal * slopeLen)
slopeScore = math.max(math.min(slopeRaw, 1.0), -1.0)

// --- Weighted composite -> 0..100 ---
rawScore = (rsiScore     * 15.0 +
            rsiFastScore * 10.0 +
            macdScore    * 15.0 +
            bbScore      *  8.0 +
            momScore     * 10.0 +
            rocScore     *  5.0 +
            willrScr     *  8.0 +
            volScore     *  5.0 +
            emaTrend     * 14.0 +
            slopeScore   * 10.0) / 100.0

compositeScore = math.max(math.min((rawScore + 1.0) / 2.0 * 100.0, 100.0), 0.0)
smoothScore    = ta.ema(compositeScore, 3)

// --- Prediction ---
isBull = smoothScore >= 60.0
isBear = smoothScore <= 40.0
conf   = math.abs(smoothScore - 50.0) * 2.0

string dirLabel = "NEUTRAL"
if isBull
    dirLabel := "UP"
if isBear
    dirLabel := "DOWN"

// --- Consensus (3 voters) ---
int vote1 = isBull ? 1 : isBear ? -1 : 0

int vote2 = 0
if histLine > 0 and close > ema26
    vote2 := 1
if histLine < 0 and close < ema26
    vote2 := -1

int vote3 = 0
if rsiVal > 55 and momVal > 0
    vote3 := 1
if rsiVal < 45 and momVal < 0
    vote3 := -1

int totalVotes = vote1 + vote2 + vote3

string consLabel = "MIXED"
if totalVotes >= 2
    consLabel := "BULLISH"
if totalVotes <= -2
    consLabel := "BEARISH"

// --- Background ---
color bgCol = color.new(color.gray, 95)
if isBull
    bgCol := color.new(color.green, 90)
if isBear
    bgCol := color.new(color.red, 90)
bgcolor(bgCol)

// --- Signal arrows ---
longEntry  = isBull and not isBull[1] and showSignals
shortEntry = isBear and not isBear[1] and showSignals

plotshape(longEntry,  title="Buy Signal",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)
plotshape(shortEntry, title="Sell Signal", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)

// --- Data window ---
plot(smoothScore, "Prediction Score", color=color.new(color.blue, 100), display=display.data_window)
plot(conf,        "Confidence %",     color=color.new(color.blue, 100), display=display.data_window)

// --- Dashboard Table ---
if showTable and barstate.islast
    var tbl = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 20), border_width=1)

    color dirColor = color.gray
    if isBull
        dirColor := color.green
    if isBear
        dirColor := color.red

    color consColor = color.orange
    if totalVotes >= 2
        consColor := color.green
    if totalVotes <= -2
        consColor := color.red

    color rsiColor = color.white
    if rsiVal > 60
        rsiColor := color.green
    if rsiVal < 40
        rsiColor := color.red

    color macdColor = color.red
    if histLine > 0
        macdColor := color.green

    color wrColor = color.white
    if willrVal < -80
        wrColor := color.green
    if willrVal > -20
        wrColor := color.red

    color volColor = color.white
    if volRatio > 1.5
        volColor := color.green

    table.cell(tbl, 0, 0, "SYGNIF Predict", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(tbl, 1, 0, "5m BTC",          text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))

    table.cell(tbl, 0, 1, "Direction",  text_color=color.gray,  text_size=size.small)
    table.cell(tbl, 1, 1, dirLabel,     text_color=dirColor,    text_size=size.normal)

    table.cell(tbl, 0, 2, "Confidence", text_color=color.gray,  text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(math.round(conf, 1)) + "%", text_color=dirColor, text_size=size.normal)

    table.cell(tbl, 0, 3, "Score",      text_color=color.gray,  text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(math.round(smoothScore, 1)) + " / 100", text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 4, "Consensus",  text_color=color.gray,  text_size=size.small)
    table.cell(tbl, 1, 4, consLabel,    text_color=consColor,   text_size=size.normal)

    table.cell(tbl, 0, 5, "",           text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 5, "",           text_color=color.gray,  text_size=size.tiny)

    table.cell(tbl, 0, 6, "RSI",        text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 6, str.tostring(math.round(rsiVal, 1)),     text_color=rsiColor,  text_size=size.tiny)

    table.cell(tbl, 0, 7, "MACD Hist",  text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 7, str.tostring(math.round(histLine, 1)),   text_color=macdColor, text_size=size.tiny)

    table.cell(tbl, 0, 8, "Will %R",    text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 8, str.tostring(math.round(willrVal, 1)),   text_color=wrColor,   text_size=size.tiny)

    table.cell(tbl, 0, 9, "Vol Ratio",  text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 9, str.tostring(math.round(volRatio, 2)) + "x", text_color=volColor, text_size=size.tiny)

// --- Alerts ---
alertcondition(longEntry,  title="SYGNIF Buy",  message="SYGNIF 5m: BTC flipped BULLISH")
alertcondition(shortEntry, title="SYGNIF Sell", message="SYGNIF 5m: BTC flipped BEARISH")
