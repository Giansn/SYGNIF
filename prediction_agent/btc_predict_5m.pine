//@version=6
strategy("SYGNIF BTC 5m", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_value=0.06, slippage=2, initial_capital=10000, max_boxes_count=500, max_labels_count=500, process_orders_on_close=true)

// ── Inputs ──
srLen    = input.int(20,    "S/R Lookback", minval=10)
fibLen   = input.int(50,    "Fib Lookback", minval=20)
zoneAtr  = input.float(0.3, "Zone Thickness (x ATR)", step=0.1)
slMul    = input.float(0.75,"SL (x ATR)", step=0.25)
maxZones = input.int(8,     "Max Zones Each Side", minval=3)
minBody  = input.float(0.2, "Min Body % for Strong Candle", step=0.05)
minVol   = input.float(1.8, "Min Vol Ratio for Strong Candle", step=0.1)
tbl      = input.bool(true, "Dashboard")

// ── Indicators ──
atr    = ta.atr(14)
rsiV   = ta.rsi(close, 14)
[ml, sl, hl] = ta.macd(close, 12, 26, 9)
vr     = volume / ta.sma(volume, 20)
e20    = ta.ema(close, 20)
e50_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
htfUp  = close > e50_1h
htfDn  = close < e50_1h

// Sideways filter: ADX < 20 = choppy, suppress signals
adxVal = ta.rma(math.abs(ta.change(ta.highest(high, 14)) - ta.change(ta.lowest(low, 14))), 14)
choppy = ta.atr(5) / ta.atr(20) < 0.8 and math.abs(close - e20) / atr < 0.5

// S/R
resLvl = ta.highest(high, srLen)
supLvl = ta.lowest(low, srLen)

// Fibonacci
fibHi  = ta.highest(high, fibLen)
fibLo  = ta.lowest(low, fibLen)
fibRng = fibHi - fibLo
fib236 = fibHi - fibRng * 0.236
fib382 = fibHi - fibRng * 0.382
fib500 = fibHi - fibRng * 0.500
fib618 = fibHi - fibRng * 0.618
fib786 = fibHi - fibRng * 0.786

zt = atr * zoneAtr

// ── Zone arrays ──
var array<float> dT = array.new_float(0)
var array<float> dB = array.new_float(0)
var array<int>   dI = array.new_int(0)
var array<int>   dR = array.new_int(0)
var array<box>   dX = array.new_box(0)
var array<label> dL = array.new_label(0)
var array<float> sT2 = array.new_float(0)
var array<float> sB2 = array.new_float(0)
var array<int>   sI = array.new_int(0)
var array<int>   sR = array.new_int(0)
var array<box>   sX = array.new_box(0)
var array<label> sL2 = array.new_label(0)

var float lastDemLvl = 0.0
var float lastSupLvl = 0.0
var float lastFibDem = 0.0
var float lastFibSup = 0.0

// Trade log
var int totalTrades = 0
var int wins = 0
var int losses = 0
var float totalPnl = 0.0

addDem(float top, float btm, string src) =>
    array.push(dT, top)
    array.push(dB, btm)
    array.push(dI, bar_index)
    array.push(dR, 0)
    array.push(dX, box.new(bar_index, top, bar_index + 5, btm, border_color=color.green, bgcolor=color.new(color.green, 65)))
    array.push(dL, label.new(bar_index + 3, top, "D", style=label.style_label_left, color=color.new(color.green, 30), textcolor=color.white, size=size.tiny, tooltip="Demand: " + src))
    if array.size(dT) > maxZones
        array.shift(dT)
        array.shift(dB)
        array.shift(dI)
        array.shift(dR)
        box.delete(array.shift(dX))
        label.delete(array.shift(dL))

addSup(float top, float btm, string src) =>
    array.push(sT2, top)
    array.push(sB2, btm)
    array.push(sI, bar_index)
    array.push(sR, 0)
    array.push(sX, box.new(bar_index, top, bar_index + 5, btm, border_color=color.red, bgcolor=color.new(color.red, 65)))
    array.push(sL2, label.new(bar_index + 3, btm, "S", style=label.style_label_left, color=color.new(color.red, 30), textcolor=color.white, size=size.tiny, tooltip="Supply: " + src))
    if array.size(sT2) > maxZones
        array.shift(sT2)
        array.shift(sB2)
        array.shift(sI)
        array.shift(sR)
        box.delete(array.shift(sX))
        label.delete(array.shift(sL2))

// ── Create zones (only when NOT choppy) ──
supBounce = low <= supLvl + zt and close > supLvl and close > open
if supBounce and math.abs(supLvl - lastDemLvl) > atr and not choppy
    addDem(supLvl + zt, supLvl - zt * 0.5, "Support")
    lastDemLvl := supLvl

resReject = high >= resLvl - zt and close < resLvl and close < open
if resReject and math.abs(resLvl - lastSupLvl) > atr and not choppy
    addSup(resLvl + zt * 0.5, resLvl - zt, "Resistance")
    lastSupLvl := resLvl

fib618b = low <= fib618 + zt and close > fib618 and close > open
fib786b = low <= fib786 + zt and close > fib786 and close > open
if (fib618b or fib786b) and math.abs((fib618b ? fib618 : fib786) - lastFibDem) > atr
    fibLvl = fib618b ? fib618 : fib786
    addDem(fibLvl + zt, fibLvl - zt * 0.5, fib618b ? "Fib 61.8%" : "Fib 78.6%")
    lastFibDem := fibLvl

fib236r = high >= fib236 - zt and close < fib236 and close < open
fib382r = high >= fib382 - zt and close < fib382 and close < open
if (fib236r or fib382r) and math.abs((fib236r ? fib236 : fib382) - lastFibSup) > atr
    fibLvl = fib236r ? fib236 : fib382
    addSup(fibLvl + zt * 0.5, fibLvl - zt, fib236r ? "Fib 23.6%" : "Fib 38.2%")
    lastFibSup := fibLvl

bodyPct = math.abs(close - open) / close * 100
bigBull = close > open and bodyPct > minBody and vr > minVol
bigBear = close < open and bodyPct > minBody and vr > minVol
if bigBull and math.abs(low - lastDemLvl) > atr and not choppy
    addDem(math.min(open, close), low, "Strong bull")
    lastDemLvl := low
if bigBear and math.abs(high - lastSupLvl) > atr and not choppy
    addSup(high, math.max(open, close), "Strong bear")
    lastSupLvl := high

fib500db = low <= fib500 + zt and close > fib500 and close > open
fib500sr = high >= fib500 - zt and close < fib500 and close < open
if fib500db and math.abs(fib500 - lastFibDem) > atr
    addDem(fib500 + zt, fib500 - zt * 0.5, "Fib 50%")
    lastFibDem := fib500
if fib500sr and math.abs(fib500 - lastFibSup) > atr
    addSup(fib500 + zt * 0.5, fib500 - zt, "Fib 50%")
    lastFibSup := fib500

// ── Update zones + detect touch ──
bool hitDemand = false
bool hitSupply = false
float bestDConf = 0.0
float bestSConf = 0.0

if array.size(dT) > 0
    for i = array.size(dT) - 1 to 0
        ztt = array.get(dT, i)
        zb = array.get(dB, i)
        zbar = array.get(dI, i)
        zret = array.get(dR, i)
        bx = array.get(dX, i)
        lb = array.get(dL, i)
        age = math.min(bar_index - zbar, 300)
        ht = (ztt - zb) / close * 100
        conf = math.min(ht * 40 + age * 0.15 + zret * 25 + (htfUp ? 12.0 : 0.0), 100.0)
        tier = conf >= 70 ? "A+" : conf >= 50 ? "A" : conf >= 30 ? "B" : "C"
        tr2 = math.round(math.max(70 - conf * 0.45, 20))
        box.set_bgcolor(bx, color.new(color.green, tr2))
        box.set_right(bx, bar_index + 5)
        label.set_x(lb, bar_index + 4)
        label.set_y(lb, ztt)
        label.set_text(lb, tier)
        exp = math.round(ht * (1 + conf / 100) * 3, 2)
        label.set_tooltip(lb, "DEMAND → LONG\n" + tier + " " + str.tostring(math.round(conf, 0)) + "%\nExp: +" + str.tostring(exp) + "%\n" + str.tostring(math.round(zb, 0)) + "–" + str.tostring(math.round(ztt, 0)) + "\nRetests: " + str.tostring(zret) + "x | Age: " + str.tostring(age) + "b")
        if low <= ztt and close > ztt
            array.set(dR, i, zret + 1)
        if low <= ztt and high >= zb
            hitDemand := true
            if conf > bestDConf
                bestDConf := conf
        if close < zb - atr * 2
            box.set_bgcolor(bx, color.new(color.gray, 92))
            box.set_border_color(bx, color.new(color.gray, 85))
            label.delete(lb)
            array.remove(dT, i)
            array.remove(dB, i)
            array.remove(dI, i)
            array.remove(dR, i)
            array.remove(dX, i)
            array.remove(dL, i)

if array.size(sT2) > 0
    for i = array.size(sT2) - 1 to 0
        ztt = array.get(sT2, i)
        zb = array.get(sB2, i)
        zbar = array.get(sI, i)
        zret = array.get(sR, i)
        bx = array.get(sX, i)
        lb = array.get(sL2, i)
        age = math.min(bar_index - zbar, 300)
        ht = (ztt - zb) / close * 100
        conf = math.min(ht * 40 + age * 0.15 + zret * 25 + (htfDn ? 12.0 : 0.0), 100.0)
        tier = conf >= 70 ? "A+" : conf >= 50 ? "A" : conf >= 30 ? "B" : "C"
        tr2 = math.round(math.max(70 - conf * 0.45, 20))
        box.set_bgcolor(bx, color.new(color.red, tr2))
        box.set_right(bx, bar_index + 5)
        label.set_x(lb, bar_index + 4)
        label.set_y(lb, zb)
        label.set_text(lb, tier)
        exp = math.round(ht * (1 + conf / 100) * 3, 2)
        label.set_tooltip(lb, "SUPPLY → SHORT\n" + tier + " " + str.tostring(math.round(conf, 0)) + "%\nExp: -" + str.tostring(exp) + "%\n" + str.tostring(math.round(zb, 0)) + "–" + str.tostring(math.round(ztt, 0)) + "\nRetests: " + str.tostring(zret) + "x | Age: " + str.tostring(age) + "b")
        if high >= zb and close < zb
            array.set(sR, i, zret + 1)
        if high >= zb and low <= ztt
            hitSupply := true
            if conf > bestSConf
                bestSConf := conf
        if close > ztt + atr * 2
            box.set_bgcolor(bx, color.new(color.gray, 92))
            box.set_border_color(bx, color.new(color.gray, 85))
            label.delete(lb)
            array.remove(sT2, i)
            array.remove(sB2, i)
            array.remove(sI, i)
            array.remove(sR, i)
            array.remove(sX, i)
            array.remove(sL2, i)

// ══════════════════════════════════════════════════════════════════════════════
// FLIP — instant on same bar, candle confirms, no signal in chop
// ══════════════════════════════════════════════════════════════════════════════
isLong  = strategy.position_size > 0
isShort = strategy.position_size < 0

goLong  = hitDemand and close > open and not choppy
goShort = hitSupply and close < open and not choppy

// Track PnL from closed trades
if strategy.closedtrades > 0
    lastPnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if ta.change(strategy.closedtrades) > 0
        totalTrades += 1
        totalPnl += lastPnl
        if lastPnl > 0
            wins += 1
        else
            losses += 1

// Flip: entry reverses position instantly (process_orders_on_close=true)
if goLong and not isLong
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", loss=atr * slMul / syminfo.mintick)
    tier = bestDConf >= 70 ? "A+" : bestDConf >= 50 ? "A" : bestDConf >= 30 ? "B" : "C"
    eTip = "LONG " + tier + "\nConf: " + str.tostring(math.round(bestDConf, 0)) + "%\nSL: $" + str.tostring(math.round(atr * slMul, 0)) + "\nRSI: " + str.tostring(math.round(rsiV, 1)) + " | Vol: " + str.tostring(math.round(vr, 1)) + "x\nW/L: " + str.tostring(wins) + "/" + str.tostring(losses) + " | PnL: " + str.tostring(math.round(totalPnl, 2))
    clr = bestDConf >= 60 ? color.green : bestDConf >= 30 ? color.new(color.green, 20) : color.new(color.green, 40)
    label.new(bar_index, low - atr * 0.4, "▲" + tier, style=label.style_label_up, color=clr, textcolor=color.white, size=bestDConf >= 50 ? size.normal : size.small, tooltip=eTip)

if goShort and not isShort
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", loss=atr * slMul / syminfo.mintick)
    tier = bestSConf >= 70 ? "A+" : bestSConf >= 50 ? "A" : bestSConf >= 30 ? "B" : "C"
    eTip = "SHORT " + tier + "\nConf: " + str.tostring(math.round(bestSConf, 0)) + "%\nSL: $" + str.tostring(math.round(atr * slMul, 0)) + "\nRSI: " + str.tostring(math.round(rsiV, 1)) + " | Vol: " + str.tostring(math.round(vr, 1)) + "x\nW/L: " + str.tostring(wins) + "/" + str.tostring(losses) + " | PnL: " + str.tostring(math.round(totalPnl, 2))
    clr = bestSConf >= 60 ? color.red : bestSConf >= 30 ? color.new(color.red, 20) : color.new(color.red, 40)
    label.new(bar_index, high + atr * 0.4, "▼" + tier, style=label.style_label_down, color=clr, textcolor=color.white, size=bestSConf >= 50 ? size.normal : size.small, tooltip=eTip)

// ── Reference lines ──
plot(e50_1h, "1h EMA50", color.new(color.orange, 50), 2)
plot(fib382, "Fib 38.2", color.new(color.orange, 70), 1, plot.style_stepline)
plot(fib500, "Fib 50",   color.new(color.blue, 70),   1, plot.style_stepline)
plot(fib618, "Fib 61.8", color.new(color.green, 60),  1, plot.style_stepline)

// ── Dashboard with trade log ──
if tbl and barstate.islast
    var t = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 20), border_width=1)
    pos = isLong ? "LONG" : isShort ? "SHORT" : "FLAT"
    color pc = isLong ? color.green : isShort ? color.red : color.gray
    ac = math.max(bestDConf, bestSConf)
    at = ac >= 70 ? "A+" : ac >= 50 ? "A" : ac >= 30 ? "B" : ac > 0 ? "C" : "—"
    color cc = ac >= 60 ? color.green : ac >= 30 ? color.yellow : color.gray
    wr2 = totalTrades > 0 ? wins * 100.0 / totalTrades : 0.0
    color pnlC = totalPnl >= 0 ? color.green : color.red
    table.cell(t, 0, 0, "SYGNIF",    text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 1, 0, "5m BTC",    text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1, "Position",  text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, pos,         text_color=pc,          text_size=size.normal)
    table.cell(t, 0, 2, "Zone",      text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2, at + " " + str.tostring(math.round(ac, 0)) + "%", text_color=cc, text_size=size.normal)
    table.cell(t, 0, 3, "Trades",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3, str.tostring(totalTrades) + " (" + str.tostring(wins) + "W " + str.tostring(losses) + "L)", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 4, "Win Rate",  text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4, str.tostring(math.round(wr2, 1)) + "%", text_color=wr2 >= 50 ? color.green : color.red, text_size=size.small)
    table.cell(t, 0, 5, "Net PnL",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5, str.tostring(math.round(totalPnl, 2)), text_color=pnlC, text_size=size.normal)
    table.cell(t, 0, 6, "Zones",     text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(array.size(dT)) + "D " + str.tostring(array.size(sT2)) + "S", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 7, "RSI/Vol",   text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(math.round(rsiV, 0)) + " | " + str.tostring(math.round(vr, 1)) + "x", text_color=color.white, text_size=size.tiny)

alertcondition(goLong and not isLong,   "SYGNIF Long",  "SYGNIF: LONG")
alertcondition(goShort and not isShort, "SYGNIF Short", "SYGNIF: SHORT")
