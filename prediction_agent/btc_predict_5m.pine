//@version=6
strategy("SYGNIF BTC 5m", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_value=0.06, slippage=2, initial_capital=10000, max_boxes_count=200, max_lines_count=200)

// ── Inputs ──
pivotLen = input.int(10,    "Pivot Lookback", minval=5)
fibLen   = input.int(50,    "Fib Lookback", minval=20)
sfVol    = input.float(3.0, "Swing Fail Vol Filter %", step=0.5)
tpMul    = input.float(2.5, "TP (x ATR)", step=0.5)
slMul    = input.float(1.5, "SL (x ATR)", step=0.5)
minSc    = input.int(72,    "Min Score", minval=60, maxval=85)
cdBars   = input.int(24,    "Cooldown Bars", minval=6)
tbl      = input.bool(true, "Dashboard")
showZone = input.bool(true, "Show Liq Zones")
fibPlt   = input.bool(true, "Show Fib")

// ── Core indicators ──
rsiV = ta.rsi(close, 14)
rsiF = ta.rsi(close, 6)
[ml, sl, hl] = ta.macd(close, 12, 26, 9)
bbM  = ta.sma(close, 20)
bbS  = ta.stdev(close, 20)
bbU  = bbM + 2 * bbS
bbL  = bbM - 2 * bbS
atr  = ta.atr(14)
mom  = close - close[10]
roc  = (close - close[12]) / close[12] * 100
wr   = -100 * (ta.highest(high, 14) - close) / (ta.highest(high, 14) - ta.lowest(low, 14))
vr   = volume / ta.sma(volume, 20)
e12  = ta.ema(close, 12)
e26  = ta.ema(close, 26)
e50  = ta.ema(close, 50)
e120 = ta.ema(close, 120)

// ── Higher TF ──
e50_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
rsi_1h = request.security(syminfo.tickerid, "60", ta.rsi(close, 14))
htfUp  = close > e50_1h and rsi_1h > 45
htfDn  = close < e50_1h and rsi_1h < 55

// ── Fibonacci ──
fibHi  = ta.highest(high, fibLen)
fibLo  = ta.lowest(low, fibLen)
fibRng = fibHi - fibLo
fib236 = fibHi - fibRng * 0.236
fib382 = fibHi - fibRng * 0.382
fib500 = fibHi - fibRng * 0.500
fib618 = fibHi - fibRng * 0.618
fib786 = fibHi - fibRng * 0.786

float fibScore = 0.0
if close <= fib618 and close >= fib786
    fibScore := 1.0
else if close <= fib382 and close > fib618
    fibScore := 0.5
else if close > fib236
    fibScore := -0.7

fibLongBoost  = (low <= fib618 and close > fib618 and close > open) or (low <= fib786 and close > fib786 and close > open)
fibShortBoost = (high >= fib236 and close < fib236 and close < open) or (high >= fib382 and close < fib382 and close < open)

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWINGS (pivot-based, inspired by LuxAlgo concept)
// ══════════════════════════════════════════════════════════════════════════════

// Detect real swing points via pivots
ph = ta.pivothigh(pivotLen, pivotLen)
pl = ta.pivotlow(pivotLen, pivotLen)

// Track swing high zone (wick top to body top)
var float shTop = na   // wick high
var float shBtm = na   // body top (max of open, close)
var int   shBar = 0
var int   shRetests = 0
var float shVol = 0.0
var bool  shSwept = false

if not na(ph)
    shTop     := high[pivotLen]
    shBtm     := math.max(open[pivotLen], close[pivotLen])
    shBar     := bar_index - pivotLen
    shRetests := 0
    shVol     := 0.0
    shSwept   := false

// Track swing low zone (wick low to body low)
var float slTop = na   // body bottom (min of open, close)
var float slBtm = na   // wick low
var int   slBar = 0
var int   slRetests = 0
var float slVol = 0.0
var bool  slSwept = false

if not na(pl)
    slTop     := math.min(open[pivotLen], close[pivotLen])
    slBtm     := low[pivotLen]
    slBar     := bar_index - pivotLen
    slRetests := 0
    slVol     := 0.0
    slSwept   := false

// Count retests: price enters the zone but doesn't break through
if not shSwept and not na(shTop)
    if high >= shBtm and high <= shTop and close < shBtm
        shRetests += 1
        shVol += volume

if not slSwept and not na(slBtm)
    if low <= slTop and low >= slBtm and close > slTop
        slRetests += 1
        slVol += volume

// Sweep detection: price breaks through zone then reverses
shSweepBar = not shSwept and high > shTop and close < shTop and close < open
slSweepBar = not slSwept and low < slBtm and close > slBtm and close > open

if high > shTop
    shSwept := true
if low < slBtm
    slSwept := true

// Liquidity density: more retests = more stops stacked = stronger reaction expected
liqDensityHi = shRetests
liqDensityLo = slRetests

// Sweep quality: volume on sweep bar vs average (real liquidity taken)
sweepVolHi = shSweepBar and vr > 1.3
sweepVolLo = slSweepBar and vr > 1.3

// Distance to liq zones (ATR-normalized)
distToSH = na(shTop) ? 99.0 : (shTop - close) / atr
distToSL = na(slBtm) ? 99.0 : (close - slBtm) / atr

// Magnet effect: price approaching liq zone with momentum
liqMagnetUp = distToSH < 3 and distToSH > 0 and mom > 0
liqMagnetDn = distToSL < 3 and distToSL > 0 and mom < 0

// ── Failure Swing (uses pivot S/R, not simple highest) ──
volPct = math.abs(close - e120) / e120 * 100
sfVolOk = volPct > sfVol

// Swing fail = sweep + reversal + volatility filter
fsLong  = slSweepBar and sfVolOk and liqDensityLo >= 1
fsShort = shSweepBar and sfVolOk and liqDensityHi >= 1

// ── Composite liq + sweep score ──
float liqScore = 0.0
if sweepVolLo or fsLong
    liqScore := 1.0
else if sweepVolHi or fsShort
    liqScore := -1.0
else if liqMagnetDn
    liqScore := -0.4
else if liqMagnetUp
    liqScore := 0.4
else if distToSL < 2
    liqScore := -0.2
else if distToSH < 2
    liqScore := 0.2

// ── Scoring (13 indicators) ──
s1  = (rsiV - 50) / 50
s2  = (rsiF - 50) / 50
s3  = hl > 0 ? math.min(hl / atr, 1.0) : math.max(hl / atr, -1.0)
s4  = ((close - bbL) / (bbU - bbL) - 0.5) * 2
s5  = math.max(math.min(mom / atr / 3, 1.0), -1.0)
s6  = math.max(math.min(roc / 3, 1.0), -1.0)
s7  = -(wr + 50) / 50
s8  = mom > 0 ? math.min((vr - 1) / 2, 1.0) : -math.min((vr - 1) / 2, 1.0)
float s9 = 0.0
if close > e12 and e12 > e26
    s9 := 1.0
else if close < e12 and e12 < e26
    s9 := -1.0
else
    s9 := math.max(math.min((close - e26) / atr * 0.3, 1.0), -1.0)
s10 = math.max(math.min((close - close[5]) / (atr * 5), 1.0), -1.0)
s11 = fibScore
s12 = liqScore
float s13 = 0.0
if fsLong
    s13 := 1.0
else if fsShort
    s13 := -1.0

raw = s1*10 + s2*6 + s3*10 + s4*5 + s5*7 + s6*3 + s7*5 + s8*3 + s9*9 + s10*6 + s11*12 + s12*12 + s13*12
score = ta.ema(math.max(math.min((raw/100 + 1) / 2 * 100, 100.0), 0.0), 5)

// ── Consensus — 6 voters ──
v1 = score >= 60 ? 1 : score <= 40 ? -1 : 0
v2 = hl > 0 and close > e26 ? 1 : hl < 0 and close < e26 ? -1 : 0
v3 = rsiV > 55 and mom > 0 ? 1 : rsiV < 45 and mom < 0 ? -1 : 0
v4 = fibScore >= 0.5 ? 1 : fibScore <= -0.5 ? -1 : 0
v5 = liqScore >= 0.5 ? 1 : liqScore <= -0.5 ? -1 : 0
v6 = s13 >= 0.5 ? 1 : s13 <= -0.5 ? -1 : 0
votes = v1 + v2 + v3 + v4 + v5 + v6

// ── Entry paths ──
bullBase     = score >= minSc and votes >= 4 and vr > 1.2 and htfUp and close > e50 and rsiV < 70
bearBase     = score <= (100 - minSc) and votes <= -4 and vr > 1.2 and htfDn and close < e50 and rsiV > 30
sfLongEntry  = fsLong and htfUp and votes >= 2 and rsiV < 45 and liqDensityLo >= 2
sfShortEntry = fsShort and htfDn and votes <= -2 and rsiV > 55 and liqDensityHi >= 2
sweepLong    = sweepVolLo and fibLongBoost and htfUp and rsiV < 40
sweepShort   = sweepVolHi and fibShortBoost and htfDn and rsiV > 60

bull = bullBase or sfLongEntry or sweepLong
bear = bearBase or sfShortEntry or sweepShort

var int lastEntry = 0
cooled = bar_index - lastEntry >= cdBars
flat   = strategy.position_size == 0

// ── TP: EMA120 for swing fails, fib levels, fallback ATR ──
float tpLong = atr * tpMul
if fsLong and e120 > close and e120 - close > atr
    tpLong := e120 - close
else if close < fib500 and fib382 - close > atr
    tpLong := fib382 - close
else if close < fib618 and fib500 - close > atr
    tpLong := fib500 - close

float tpShort = atr * tpMul
if fsShort and close > e120 and close - e120 > atr
    tpShort := close - e120
else if close > fib500 and close - fib618 > atr
    tpShort := close - fib618
else if close > fib382 and close - fib500 > atr
    tpShort := close - fib500

slD = atr * slMul

if bull and cooled and flat
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", profit=tpLong / syminfo.mintick, loss=slD / syminfo.mintick)
    lastEntry := bar_index

if bear and cooled and flat
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", profit=tpShort / syminfo.mintick, loss=slD / syminfo.mintick)
    lastEntry := bar_index

// ── Visuals ──
// Liq zones as boxes
var box shBox = na
var box slBox = na

if not na(ph) and showZone
    shBox := box.new(shBar, shTop, bar_index, shBtm, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 88))
if not shSwept and not na(shBox) and showZone
    box.set_right(shBox, bar_index + 3)
if shSwept and not shSwept[1] and not na(shBox)
    box.set_right(shBox, bar_index)

if not na(pl) and showZone
    slBox := box.new(slBar, slTop, bar_index, slBtm, border_color=color.new(color.teal, 60), bgcolor=color.new(color.teal, 88))
if not slSwept and not na(slBox) and showZone
    box.set_right(slBox, bar_index + 3)
if slSwept and not slSwept[1] and not na(slBox)
    box.set_right(slBox, bar_index)

// Fib levels
plot(fibPlt ? fib382 : na, "Fib 38.2%", color.new(color.orange, 50), 1, plot.style_cross)
plot(fibPlt ? fib500 : na, "Fib 50%",   color.new(color.blue, 50),   1, plot.style_cross)
plot(fibPlt ? fib618 : na, "Fib 61.8%", color.new(color.green, 40),  2, plot.style_cross)
plot(e50_1h, "1h EMA50", color.new(color.orange, 40), 2)
plot(e120,   "EMA120",   color.new(color.yellow, 50), 1)

// Sweep markers
plotshape(sweepVolLo, "Sweep Long",  shape.diamond, location.belowbar, color.new(color.lime, 0),    size=size.small)
plotshape(sweepVolHi, "Sweep Short", shape.diamond, location.abovebar, color.new(color.fuchsia, 0),  size=size.small)
plotshape(fsLong and not sweepVolLo,  "SF Long",  shape.cross, location.belowbar, color.new(color.lime, 20),    size=size.small)
plotshape(fsShort and not sweepVolHi, "SF Short", shape.cross, location.abovebar, color.new(color.fuchsia, 20),  size=size.small)

color bg = color.new(color.gray, 97)
if score >= 60
    bg := color.new(color.green, 93)
if score <= 40
    bg := color.new(color.red, 93)
bgcolor(bg)

plot(score, "Score", color.new(color.blue, 100), display=display.data_window)

// ── Dashboard ──
if tbl and barstate.islast
    var t = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 20), border_width=1)
    dir = score >= minSc ? "LONG" : score <= (100 - minSc) ? "SHORT" : "FLAT"
    con = votes >= 4 ? "STRONG" : votes >= 3 ? "BULLISH" : votes <= -4 ? "STRONG" : votes <= -3 ? "BEARISH" : "WAIT"
    color dc = score >= minSc ? color.green : score <= (100 - minSc) ? color.red : color.gray
    color cc = math.abs(votes) >= 4 ? (votes > 0 ? color.green : color.red) : math.abs(votes) >= 3 ? (votes > 0 ? color.green : color.red) : color.orange
    htf = htfUp ? "UP" : htfDn ? "DOWN" : "FLAT"
    color hc = htfUp ? color.green : htfDn ? color.red : color.gray
    fibZ = fibScore >= 0.5 ? "BUY" : fibScore <= -0.5 ? "SELL" : "—"
    color fc = fibScore >= 0.5 ? color.green : fibScore <= -0.5 ? color.red : color.gray
    liqZ = sweepVolLo or fsLong ? "SWEPT L" : sweepVolHi or fsShort ? "SWEPT S" : liqMagnetDn ? "MAGNET DN" : liqMagnetUp ? "MAGNET UP" : "CLEAR"
    color lc = liqScore >= 0.5 ? color.green : liqScore <= -0.5 ? color.red : math.abs(liqScore) > 0.2 ? color.orange : color.gray
    rHi = na(shRetests) ? "—" : str.tostring(shRetests) + "x"
    rLo = na(slRetests) ? "—" : str.tostring(slRetests) + "x"
    table.cell(t, 0, 0,  "SYGNIF",     text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 1, 0,  "5m BTC",     text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1,  "Bias",       text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1,  dir,          text_color=dc,          text_size=size.normal)
    table.cell(t, 0, 2,  "1h Trend",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2,  htf,          text_color=hc,          text_size=size.normal)
    table.cell(t, 0, 3,  "Fib",        text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3,  fibZ,         text_color=fc,          text_size=size.normal)
    table.cell(t, 0, 4,  "Liq",        text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4,  liqZ,         text_color=lc,          text_size=size.normal)
    table.cell(t, 0, 5,  "Retests",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5,  "H:" + rHi + " L:" + rLo, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 6,  "Consensus",  text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 6,  con + " " + str.tostring(votes) + "/6", text_color=cc, text_size=size.small)
    table.cell(t, 0, 7,  "Score",      text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 7,  str.tostring(math.round(score, 1)), text_color=dc, text_size=size.tiny)
    float tpS = strategy.position_size > 0 ? tpLong : tpShort
    table.cell(t, 0, 8,  "TP / SL",    text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 8,  str.tostring(math.round(tpS, 0)) + " / " + str.tostring(math.round(slD, 0)), text_color=color.white, text_size=size.tiny)
    shStr = na(shTop) ? "—" : str.tostring(math.round(shTop, 0))
    slStr = na(slBtm) ? "—" : str.tostring(math.round(slBtm, 0))
    table.cell(t, 0, 9,  "Swing H/L",  text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 9,  shStr + " / " + slStr, text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 10, "ATR",        text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(math.round(atr, 0)),   text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 11, "Vol",        text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 11, str.tostring(math.round(vr, 2)) + "x", text_color=vr > 1.2 ? color.green : color.white, text_size=size.tiny)

alertcondition(bull and cooled and flat, "SYGNIF Long",  "SYGNIF: BTC LONG")
alertcondition(bear and cooled and flat, "SYGNIF Short", "SYGNIF: BTC SHORT")
