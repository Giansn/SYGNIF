# -----------------------------------------------------------------------------
# Safe place for tokens (never commit real values)
# -----------------------------------------------------------------------------
# 1) Copy this file to **`.env`** in the same directory as `docker-compose.yml` (repo root, e.g. `~/SYGNIF/.env`).
# 2) That **`.env`** file is listed in **`.gitignore`** — put API keys, bot tokens, and secrets there only.
# 3) Optional extra local files (also gitignored): **`.env.local`**, **`.env.secrets`** — same `KEY=value` lines; load order depends on the tool (Docker Compose uses `env_file: .env` by default).
# 4) Do **not** paste secrets into tracked files (`config.json` in git, README, Telegram, etc.).
# -----------------------------------------------------------------------------

# Copy to .env and fill in. Used by docker-compose, notification_handler, and systemd dashboard units.

# Bybit (Freqtrade)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Nautilus research → Bybit HTTP adapter (btc-nautilus compose / OHLCV sink)
# Public 1h klines may work without keys; for signed demo API use keys from Bybit demo UI:
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
# Freqtrade BTC 0.1 futures demo: merge into gitignored user_data/config_futures.json — see letscrash/BTC_STRATEGY_0_1_BYBIT_BRIDGE.md + user_data/config_btc_strategy_0_1_bybit_demo.example.json
# btc+nautilus merge compose defaults NAUTILUS_BYBIT_DEMO to true; set false for mainnet public bars only.
NAUTILUS_BYBIT_DEMO=true
NAUTILUS_BYBIT_TESTNET=false
# Nautilus sink loop interval (seconds). 1800 = 30m inflow; ruleprediction-pipeline.timer is hourly on the host.
NAUTILUS_BYBIT_POLL_SEC=1800
NAUTILUS_BTC_BAR_LIMIT=900
# Nautilus → training feed (bar limits + order book / trades caps)
NAUTILUS_TRAINING_BAR_LIMIT_1H=1600
NAUTILUS_TRAINING_BAR_LIMIT_1D=120
NAUTILUS_TRAINING_TRADES_LIMIT=120
NAUTILUS_TRAINING_BOOK_LEVELS=50
NAUTILUS_TRAINING_BOOK_DELTA_CAP=120

# Freqtrade REST API — use one style consistently (password must match api_server in config).
FREQTRADE_API_USERNAME=freqtrader
FT_SPOT_USER=freqtrader
FT_SPOT_PASS=
# Futures REST (config_futures.json api_server) — use its own password; quote value if it contains spaces or shell-special chars
FT_FUTURES_USER=freqtrader
FT_FUTURES_PASS=
# Shared API password fallback (dashboards try FREQTRADE → FT_* → API_PASSWORD)
API_PASSWORD=
# If the password contains $, write each $ as $$ so Docker Compose does not treat $foo as a variable.
FREQTRADE_API_PASSWORD=

# JWT for Freqtrade API (config_futures api_server.jwt_secret_key)
JWT_SECRET_KEY=
# Legacy optional alias
FT_FUTURES_JWT_SECRET=

# Telegram — spot bot (Freqtrade config.json + optional webhooks)
# notification_handler also accepts FINANCE_BOT_TOKEN + AGENT_CHAT_ID if these are empty.
TELEGRAM_BOT_TOKEN=
# Futures bot (config_futures.json telegram + notification_handler webhooks to @sygnifuture_bot)
TELEGRAM_FUTURES_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dedicated overseer bot token (recommended for @Sygnif_hedge_bot)
SYGNIF_HEDGE_BOT_TOKEN=

# Freqtrade futures API JWT (must match a stable secret; generate random hex if needed)
FT_FUTURES_JWT_SECRET=

# Optional: Anthropic (notification_handler trade reviews)
ANTHROPIC_API_KEY=

# --- Docker stack: shared network + service URLs (existing “nodes” = container DNS on that network) ---
# All compose services attach to logical network key `sygnif_backend`.
#
# A) Default: Compose creates a bridge named SYGNIF_DOCKER_NETWORK_NAME (default sygnif_backend).
#
# B) “Sygnif Network” — use a pre-created external bridge (same host / EC2):
#    docker network create sygnif_network
#    export COMPOSE_FILE=docker-compose.yml:docker-compose.sygnif-network.yml
#    # optional: SYGNIF_EXTERNAL_NETWORK_NAME=my_custom_name
#    docker compose up -d
#    (Merge file: docker-compose.sygnif-network.yml; SYGNIF_DOCKER_NETWORK_NAME is not used then.)
#
SYGNIF_EXTERNAL_NETWORK_NAME=sygnif_network
# Point these at another stack on the *same* Docker network by using that service’s name, e.g.
#   SYGNIF_SENTIMENT_HTTP_URL=http://my-finance-sidecar:8091/sygnif/sentiment
# To use a finance-agent already listening on the EC2 host (systemd), use host.docker.internal
# (extra_hosts is set in docker-compose for freqtrade / futures / trade-overseer):
#   SYGNIF_SENTIMENT_HTTP_URL=http://host.docker.internal:8091/sygnif/sentiment
#   FINANCE_AGENT_BRIEFING_URL=http://host.docker.internal:8091/briefing
#   OVERSEER_AGENT_URL=http://host.docker.internal:8091/overseer/commentary
SYGNIF_DOCKER_NETWORK_NAME=sygnif_backend
SYGNIF_SENTIMENT_HTTP_URL=http://finance-agent:8091/sygnif/sentiment
# Freqtrade user_data/strategies/SygnifStrategy.py: which implementation backs the SygnifStrategy class.
# sygnif (default) = _SygnifStrategyDefault (HTTP sentiment when configured). ms2 | marketstrategy2 = subclass MarketStrategy2.
# Restart Freqtrade after changing; import-time only.
# SYGNIF_STRATEGY_BACKEND=ms2
# Optional: btc_trend = BTC-only entries via user_data/strategies/btc_trend_regime.py (tag btc_trend_long); unset = full Sygnif stack. See docs/btc_trend_backtest_checklist.md.
# SYGNIF_PROFILE=btc_trend
# Docker: service freqtrade-btc-0-1 sets SYGNIF_PROFILE=btc_trend in-container; start with: docker compose --profile btc-0-1 up -d freqtrade-btc-0-1
FINANCE_AGENT_BRIEFING_URL=http://finance-agent:8091/briefing
# Overseer LLM commentary (POST); same host as finance-agent HTTP when using the bundled image
OVERSEER_AGENT_URL=http://finance-agent:8091/overseer/commentary
OVERSEER_AGENT_TOKEN=
# Optional /briefing (8091): R01/R02 lines when training_channel_output.json or rule registry mtimes change (in-process dedupe).
# SYGNIF_BRIEFING_INCLUDE_RULE_PREDICT=1
# Optional: one compact line from btc_prediction_output.json when file age < SYGNIF_BRIEFING_BTC_PREDICT_MAX_AGE_H (default 24).
# SYGNIF_BRIEFING_INCLUDE_BTC_PREDICT=1
# prediction_horizon_check.py save: append horizon row to prediction_agent/rule_tag_journal.csv when set.
# RULE_TAG_JOURNAL=1
# RULE_TAG_JOURNAL_TAG=BTC-0.1-R03

# Optional: override Freqtrade API base URLs if your trader containers use different hostnames
# FT_SPOT_URL=http://freqtrade:8080/api/v1
# FT_FUTURES_URL=http://freqtrade-futures:8081/api/v1

# Finance-agent HTTP container: LLM (same as Telegram bot stack)
# CURSOR_API_KEY=
# CURSOR_AGENT_REPOSITORY=https://github.com/you/SYGNIF
# CURSOR_AGENT_REF=main
# Optional: LLM_BACKEND=ollama + OLLAMA_MODEL=... if not using Cursor Cloud

# Optional: NewHedge.io metrics API (token required — unauthenticated returns 401). Used by finance_agent/newhedge_client.py and scripts/market_open_context_report.py.
# NEWHEDGE_API_KEY=

# Optional: CoinGecko Pro — `x-cg-pro-api-key` for `pull_btc_extended_history.py` (Pro host). Free tier: leave unset.
# COINGECKO_API_KEY=

# Optional: Crypto APIs — https://app.cryptoapis.io/api-keys — header X-API-Key; BTC mainnet + market-data via finance_agent/cryptoapis_client.py → btc_cryptoapis_foundation.json (pull_btc_context.py).
# cryptoapi_Token=

# Dashboard BTC context: run pull with finance-agent LLM analysis (same llm_analyze + KB as /finance-agent). Set 0 for fast pull / no Cursor.
# CRYPTO_CONTEXT_LLM=1
# Optional: only run LLM when cursor-agent-worker is healthy (GET CURSOR_WORKER_HEALTH_URL, default :8093/healthz). Else heuristic fallback.
# CRYPTO_CONTEXT_REQUIRE_WORKER=1

# Orthogonal / nn-zero-to-hero — finance-agent GET /training discovers Jupyter + paths
# ORTHOGONAL_TRAINING_BASE=http://host.docker.internal:8890
# ORTHOGONAL_TRAINING_HOST=host.docker.internal
# ORTHOGONAL_TRAINING_PORT=8890
# NN_ZERO_TO_HERO_ROOT=/home/ubuntu/nn-zero-to-hero

# Sentiment MLP (train: finance_agent/scripts/train_sentiment_mlp.py → user_data/finance_agent/sentiment_mlp.npz)
# SENTIMENT_MLP_ENABLED=1
# SENTIMENT_MLP_WEIGHTS=/app/finance_agent_models/sentiment_mlp.npz
# SENTIMENT_MLP_ALPHA=0.45
# Train with real closes: python3 finance_agent/scripts/train_sentiment_mlp.py --freqtrade-db user_data/tradesv3-futures.sqlite --print-analysis
# Analysis only: python3 finance_agent/scripts/analyze_closed_trades.py --db user_data/tradesv3-futures.sqlite --json

# Optional: Giansn/Network NN sidecar — GET body is appended to `/finance-agent network nodes` and `/sygnif` cycle (truncated)
# NETWORK_NN_STATUS_URL=http://127.0.0.1:8095/nn-status

# -----------------------------------------------------------------------------
# Reverse SSH tunnel (EC2 → gateway) — “constant host” for a local dashboard
# -----------------------------------------------------------------------------
# EC2 runs ssh -N -R … so your VPS/home box exposes a port that forwards here.
# On the gateway: optional sshd_config `GatewayPorts clientspecified` or `yes` if REMOTE_BIND=0.0.0.0.
# Install unit: sudo cp systemd/sygnif-reverse-tunnel.service /etc/systemd/system/ && sudo systemctl daemon-reload
# Enable:     sudo systemctl enable --now sygnif-reverse-tunnel
# Disable:   sudo systemctl disable --now sygnif-reverse-tunnel
#
# SYGNIF_REVERSE_TUNNEL_ENABLE=1
# SYGNIF_REVERSE_TUNNEL_GATEWAY=ubuntu@your-vps.example.com
# Optional dedicated key (chmod 600): SYGNIF_REVERSE_TUNNEL_IDENTITY_FILE=/home/ubuntu/.ssh/sygnif_tunnel_ed25519
# SYGNIF_REVERSE_TUNNEL_REMOTE_BIND=127.0.0.1
# SYGNIF_REVERSE_TUNNEL_REMOTE_PORT=19891
# SYGNIF_REVERSE_TUNNEL_LOCAL_HOST=127.0.0.1
# SYGNIF_REVERSE_TUNNEL_LOCAL_PORT=8891
# Public bind on gateway (needs sshd GatewayPorts): SYGNIF_REVERSE_TUNNEL_REMOTE_BIND=0.0.0.0
# Use an SSH key for the tunnel user (BatchMode=yes — no password prompt under systemd).
