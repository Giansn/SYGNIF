[Unit]
Description=Sygnif BTC Terminal (prediction + training channel)
After=docker.service network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/SYGNIF
# Same order as compose ``x-sygnif-env-files``: secrets first, repo ``.env`` overrides.
EnvironmentFile=-/home/ubuntu/xrp_claude_bot/.env
EnvironmentFile=-/home/ubuntu/SYGNIF/.env
# Default port 8888 is in ``dashboard_server_btc_terminal.py`` / ``SYGNIF_BTC_TERMINAL_PORT`` in ``.env``.
# Mutually exclusive with ``sygnif-dashboard-spot`` on the same host port; use a drop-in or ``.env`` if 8888 is taken.
ExecStart=/usr/bin/python3 /home/ubuntu/SYGNIF/dashboard_server_btc_terminal.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
