    cli: tailscale login (opens_browser)
    gui: system_tray_icon_sign_in
  bypass_paths_no_reauth:
    x1_ssh_via_mdns:
      cmd: ssh -4 g2thek@thinkx1.local
      mechanism: mdns_lan_resolves_to_current_ip
      lan_ip: 192.168.1.109
      note: force_ipv4_mdns_returns_only_ipv6_on_this_lan
