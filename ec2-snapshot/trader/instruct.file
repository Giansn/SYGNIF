storage:
  primary: /var/lib/sygnif/swarm.db
  engine: sqlite-wal
  schema:
    columns:
    - id_TEXT_PK
    - swarm_id
    - agent_id
    - topic
    - content
    - tags
    - meta
    - created_REAL
    id_required: str(uuid.uuid4())
    write: INSERT_only_never_UPDATE
  topics:
  - forecast
  - trade.open
  - trade.close
  - regime
  - lesson
  - gap
  - proposal
  - postmortem
  - observation
  - plan
  - hypothesis
  - bee.reference
  - trader.heartbeat
  swarm_ids:
  - default
  - btc_demo
  - self_knowledge
  - self_improvement
  - session_log
  - trading
  permanence:
    backend: bee_mainnet
    upload: bee.upload(text)->bzz_ref
    backlink: insert_swarm_row_topic_bee.reference
    batch_ttl_days: 30
    bee_local_health: http://127.0.0.1:1633/health
    bee_write_host: ubuntu@3.64.28.14
  feeds: one_per_topic_head_moves_consumers_read_latest
  metrics:
    local_write_ms: 5
    bee_upload_s:
    - 2
    - 8
  antipatterns:
  - UPDATE_existing_rows
  - INSERT_without_id
  - trust_paper.json_across_versions
compute:
  model_split_2026-04-28:
    voice_second_opinion_postmortem_shadow_planner: qwen3.5_9B_sygnif-lora-v3_via_llm.advise_neuron_runpod_pod
    routing_structured_json_background: gemma_family_local_devices_x1_ollama_x1_openvino_yoga_NPU_GPU_CPU
    deterministic: pure_python_no_llm
    legacy_deprecated_2026-04-28: sygnif_ask_chat_9011_gemma1b_channeler_paths_remain_but_not_voice
  voice:
    model: qwen3.5_9B_sygnif-lora-v3
    serving: llama.cpp_on_runpod_gpu_pod
    tunnel: ssh_localhost_8080
    neuron: llm.advise
    cost_usd_per_hour_running: 0.69
    default_posture: pod_down
    lifecycle_up: sygnif-llamapod-up_or_/llama_up_in_TUI
    lifecycle_down: sygnif-llamapod-down_or_/llama_down
    failure_mode: reason=pod_down_caller_falls_back_to_rule_based_path
    shadow_planner:
      env: SYGNIF_LLM_SHADOW=1
      unit: sygnif-trader.service
      persistence_topic: trade.plan.shadow
      persistence_swarm_id: trading
      phase: 1_observation_only_no_execution_change_2_to_4_weeks_then_decide_veto_or_primary
  npu_quant: channel_wise_int4_sym_group_size_neg1
  x1_num_gpu: 0
  ollama_idle_unload_min: 10
  tier_routing:
    deterministic:
      device: pure_python
      throughput: ms
      use: sizing_dedup_review_pnl_math
    structured_json:
      device: gemma-sygnif-mini@x1_ollama
      params: 1B_q4_cpu
      ttft_s: 6
      use: routing_swarm_schema
    interactive_chat:
      device: yoga_gpu_arc_140v
      via: sygnif-yoga_mcp_9003
      throughput_tok_s: 54.8
      ttft_ms_warm: 67
      use: foreground_chat
    background_loops:
      device: yoga_npu_lunar_lake
      via: sygnif-yoga_mcp_9003
      throughput_tok_s: 41.6
      power_w: 2
      ttft_s_cold: 24
      use: low_power_background
    heavy_reasoning:
      device: x1_ollama_gemma-sygnif
      params: 7.5B_q4_cpu
      throughput_tok_s:
      - 5
      - 15
      ttft_s_cold:
      - 30
      - 60
      use: queue_patiently
    voice_runpod:
      device: runpod_gpu_pod
      model: qwen3.5_9B_sygnif-lora-v3
      serving: llama.cpp_via_ssh_tunnel_localhost_8080
      neuron: llm.advise
      cost_usd_per_hour: 0.69
      use: second_opinions_articulations_postmortems_shadow_planner_concur
  antipatterns:
  - call_7.5B_for_routing
  - call_1B_for_trading_decisions
  - load_model_per_call
  - x1_igpu_inference
  - leave_runpod_pod_up_when_idle_burns_0.69_per_hour
  - claim_qwen_forbidden_per_stale_single_model_rule
network_internal:
  primary: tailscale_magicdns
  hosts:
  - x1
  - sygnif-ec2
  - gtaura
  - yoga
  fallback: lan_mdns
  fallback_examples:
    x1: thinkx1.local -> 10.93.202.35
    ec2: ec2-eu1 -> 3.64.28.14_ssh_alias
  mcp_endpoints:
    x1_mcp: 100.71.122.115:9001/rpc
    bybit_mcp: 100.71.122.115:9002/rpc
    dashboard_prod: 100.71.122.115:8088
    dashboard_v2: 100.71.122.115:8090
  protocol: http_jsonrpc_2.0_bearer_token
  tailnet_acl: gate
  swarm_master: x1_only_ec2_writes_via_mcp
  metrics:
    x1_ec2_rtt_ms: 18
    lan_mdns_resolve_ms: 14
    mcp_call_p50_ms: 50
  antipatterns:
  - hardcode_tailscale_ip
  - bind_0.0.0.0_outside_lan
  - skip_mdns_fallback
network_external:
  bybit_mainnet:
    url: https://api.bybit.com
    use: market_truth_chains_klines_ticker_max_pain
    auth_public: none
    auth_private: hmac
  bybit_demo:
    url: https://api-demo.bybit.com
    env: BYBIT_OPTION_USE_DEMO=1
    keys: BYBIT_DEMO_*
    use: paper_orders
  bybit_demo_quirks:
    demo_apply_money_adjusttype_0: deposits_full_per_coin_allotment_regardless_of_amountstr
    demo_apply_money_adjusttype_1: DOES_execute_as_withdrawal_settles_asynchronously_retCode_0_at_submission_balance_updates_over_seconds_to_minutes_rate_limited_retCode_10006_on_rapid_retries
    max_per_call:
      usdt: 50000
      usdc: 50000
      btc: 1
      eth: 1
    option_taker_fee_pct: 0.03
  ec2_ssh:
    address: ubuntu@3.64.28.14
    eip_alloc: eipalloc-07c3927e571711ec5
    auth_persistent: id_ed25519
    auth_ondemand: ec2-instance-connect_60s_window
    iam: sygnif-agent_scoped
  bybit_rest_p50_ms: 280
  rules:
    live_clearance_phrase: clear for live
    leverage_max_default: 10
  antipatterns:
  - live_orders_without_clearance
  - trade_on_stale_snapshot_ticker_gt_10min_chain_gt_30min
  - bypass_mcp_gate_loses_dedup_audit_equity_cap
waiaas_daemon:
  role: self_custodied_multi_chain_wallet_for_non-bybit_positioning_added_2026-04-26
  host: 127.0.0.1:3100
  container_name: waiaas-daemon
  image: ghcr.io/minhoyoo-iotrust/waiaas:latest
  version_observed: 2.16.0
  chains:
  - solana_mainnet
  - ethereum_mainnet
  - polygon_mainnet
  - arbitrum_mainnet
  - optimism_mainnet
  - base_mainnet
  - hyperevm_mainnet
  - xrpl_mainnet
  master_password_location: /data/recovery.key_inside_container_volume_NEVER_in_host_shell_or_env
  session_env_file: ~/.sygnif/waiaas.env_chmod_600
  encrypted_backup_path: ~/sygnif-backups/backup-20260425-232955322.waiaas-backup
  operator_cli: ~/.local/bin/sygnif-wallet
  cli_modes:
  - sol
  - eth
  - xrp
  - all
  - raw
  - evm_<network>
  programmatic_neurons_read:
  - chain.balance
  - chain.connect_info
  - chain.history
  - chain.actions.list
  - chain.swap.quote
  programmatic_neurons_mutating_triple_gate:
  - chain.send_native
  - chain.swap.execute
  - chain.jito.stake
  - chain.jito.unstake
  - chain.kamino.supply
  - chain.kamino.withdraw
  - chain.drift.open
  - chain.drift.close
  triple_gate:
    confirm: 'True'
    i_understand_real_money: "'yes'"
    NEVER_skip_for_convenience: true
  policy_gates:
  - SPENDING_LIMIT
  - WHITELIST
  - ALLOWED_TOKENS
  - CONTRACT_WHITELIST
  default_policy: deny
  action_providers:
  - jupiter_swap
  - zerox_swap
  - lifi
  - lido_staking
  - jito_staking
  - aave_v3
  - kamino
  - pendle_yield
  - drift_perp
  - hyperliquid_spot
  - hyperliquid_perp
  - hyperliquid_sub
  - polymarket_order
  - polymarket_ctf
  - dcent_swap
  - across_bridge
  - xrpl_dex
  - erc8004_agent
  quirks:
    dryrun_v2.16.0_ignored: every_api_call_is_real_verified_2026-04-25_with_1000_lamport_loss
  telegram:
    bot_username: '@Sygnif_Agent_Bot'
    chat_id: '1134139785'
    chat_role_for_user: ADMIN
    alert_topics:
    - TX_SUBMITTED
    - TX_INCOMING
    - POLICY_VIOLATION
    - KILL_SWITCH
    security_broadcasts_bypass_filters: true
  rules:
    no_master_password_in_host_shell_or_env: docker_compose_exec_T_with_inline_PW_only
    no_dryrun_trust: every_call_real_v2.16.0
    whitelist_recipients_first: caught_address_poisoning_attack
    no_copy_addresses_from_tx_history: scammer_defense_lessons
  antipatterns:
  - bypass_triple_gate
  - export_master_password_to_host_shell
  - echo_session_token
  - head_c_response_with_token
  - blanket_allow_new_recipient_without_whitelist_review
  - trust_dryrun_field
