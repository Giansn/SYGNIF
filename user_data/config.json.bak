{
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.95,
    "fiat_display_currency": "CHF",
    "dry_run": true,
    "dry_run_wallet": 100,

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "check_depth_of_market": { "enabled": false, "bids_to_ask_delta": 1 }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },

    "exchange": {
        "name": "bybit",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "XRP/USDT",
            "BTC/USDT",
            "ETH/USDT"
        ],
        "pair_blacklist": []
    },

    "pairlists": [
        { "method": "StaticPairList" }
    ],

    "telegram": {
        "enabled": true,
        "token": "YOUR_TELEGRAM_BOT_TOKEN",
        "chat_id": "YOUR_CHAT_ID",
        "notification_settings": {
            "status": "on",
            "warning": "on",
            "startup": "on",
            "entry": "on",
            "exit": "on"
        }
    },

    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": true,
        "jwt_secret_key": "CHANGE_ME_TO_RANDOM_STRING",
        "CORS_origins": ["http://localhost:8080"],
        "username": "freqtrader",
        "password": "CHANGE_ME"
    },

    "bot_name": "XRP_Claude_Sentiment_Bot",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": { "process_throttle_secs": 5 },

    "_comment": "IMPORTANT: Start with dry_run=true! Only set to false after backtesting."
}
