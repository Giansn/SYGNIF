        },
        "ccxt_async_config": {
            "enableRateLimit": true,
            "options": {
                "defaultType": "swap",
                "defaultSettle": "USDT",
                "enableDemoTrading": true,
                "hostname": "bybit.com"
            }
        },
        "pair_whitelist": ["BTC/USDT:USDT"],
        "pair_blacklist": []
