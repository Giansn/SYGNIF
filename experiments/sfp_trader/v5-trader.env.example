# /etc/sygnif/v5-trader.env (deploy as 640, root:ubuntu)
# Loaded AFTER /etc/sygnif/trader.env (which has BYBIT_API_KEY / BYBIT_API_SECRET)

# ── Kill switches ──
# Master enable. 0 = signals logged + swarm/brain only, NO orders.
SYGNIF_V5_TRADER_ENABLED=0

# 1 = order-shape printed but no API call. Set to 0 to actually place orders.
SYGNIF_V5_DRY_RUN=1

# 0 = disable SHORT mirror (LONG-only — matches the backtested side).
SYGNIF_V5_ALLOW_SHORT=1

# 1 = forecast rows + thesis text but NEVER call the order API.
SYGNIF_V5_SIGNALS_TO_SWARM_ONLY=0


# ── Trade params ──
SYGNIF_V5_SYMBOL=BTCUSDT
SYGNIF_V5_TF_MIN=5
SYGNIF_V5_RISK_USD=10
SYGNIF_V5_SL_PCT=0.25
SYGNIF_V5_LEVERAGE=3


# ── Rate limits ──
SYGNIF_V5_COOLDOWN_S=1800
SYGNIF_V5_HEARTBEAT_S=300
SYGNIF_V5_MAX_OPEN=1


# ── Internal ──
SYGNIF_V5_BOOTSTRAP_BARS=1000
SYGNIF_BRAIN_URL=http://localhost:8889


# ── Deploy steps (copy to /etc/sygnif/v5-trader.env, then) ──
# sudo systemctl daemon-reload
# sudo systemctl enable sygnif-v5-trader
# sudo systemctl start sygnif-v5-trader
# journalctl -u sygnif-v5-trader -f
#
# ── 2-hour debug flow ──
# 1. SYGNIF_V5_TRADER_ENABLED=0 (signals to swarm only) — verify wiring
# 2. SYGNIF_V5_TRADER_ENABLED=1 + SYGNIF_V5_DRY_RUN=1 — verify fire path
# 3. SYGNIF_V5_TRADER_ENABLED=1 + SYGNIF_V5_DRY_RUN=0 — live demo orders
