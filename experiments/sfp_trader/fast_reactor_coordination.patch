+def sfp_holds_position() -> tuple[bool, str]:
+    """Check if the sygnif-sfp-trader daemon holds an open position.
+
+    Returns (holds, reason). If True, fast-reactor must stand down on perp opens.
+    """
+    try:
+        data = json.loads(CLAIM_FILE.read_text())
+    except Exception:
+        return (False, "no_claim_file")
+    for c in data.get("claims", []):
+        if c.get("status") == "open" and (c.get("owner") or "").startswith("sfp"):
+            return (True, f"sfp_open:{c.get('olid','?')[:14]}")
+    return (False, "no_sfp_open")
+
+
+def fib_zone_reject(direction: str, mid: float) -> tuple[bool, str]:
+    """Reject momentum/whale entries at extreme fib zones.
+
+    Uses the rolling 240-bar window from state['recent_bars']. Long above
+    fib_0.786 = overextended buy zone; short below fib_0.236 = capitulation
+    sell zone. Returns (reject, reason).
+    """
+    bars = list(state.get("recent_bars", []))
+    if len(bars) < 50:
+        return (False, "not_enough_bars")
+    h = max(b["high"] for b in bars); l = min(b["low"] for b in bars)
+    diff = h - l
+    if diff <= 0: return (False, "flat_range")
+    fib_236 = l + 0.236 * diff
+    fib_786 = l + 0.786 * diff
+    if direction == "long" and mid >= fib_786:
+        return (True, f"long_above_fib_0.786:${fib_786:.0f}")
+    if direction == "short" and mid <= fib_236:
+        return (True, f"short_below_fib_0.236:${fib_236:.0f}")
+    return (False, "in_zone")
+
+
