{
  "mcpServers": {
    "gitnexus": {
      "command": "node",
      "args": [
        "scripts/mcp/run-with-npx.mjs",
        "-y",
        "gitnexus@latest",
        "mcp"
      ]
    },
    "linear": {
      "command": "node",
      "args": [
        "scripts/mcp/run-with-npx.mjs",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ]
    },
    "aws-docs": {
      "command": "node",
      "args": [
        "scripts/mcp/run-with-uvx.mjs",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "aws-iac": {
      "command": "node",
      "args": [
        "scripts/mcp/run-with-uvx.mjs",
        "awslabs.iac-mcp-server@latest"
      ],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-central-1"
      }
    },
    "aws-serverless": {
      "command": "node",
      "args": [
        "scripts/mcp/run-with-uvx.mjs",
        "awslabs.aws-serverless-mcp-server@latest"
      ],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-central-1"
      }
    },
    "edge-npu": {
      "command": "node",
      "args": ["scripts/mcp/run-edge-npu.mjs"]
    },
    "brainsync": {
      "command": "node",
      "args": ["scripts/mcp/run-brainsync.mjs"]
    }
  }
}
